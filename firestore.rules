// © AngelaMos | 2026
// firestore.rules
// ===================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Events: public read; all writes via Cloud Functions (admin SDK).
    match /events/{eventId} {
      allow read: if true;
      allow write: if false;
    }

    // Bookings: never directly client-accessible. Created via `createBooking`
    // callable; read/updated only by Cloud Functions.
    match /bookings/{bookingId} {
      allow read, write: if false;
    }

    // Public config doc holds the bookingLocked flag.
    match /config/{docId} {
      allow read: if docId == 'public';
      allow write: if false;
    }

    match /telegramSessions/{chatId} {
      allow read, write: if false;
    }

    match /rateLimits/{key} {
      allow read, write: if false;
    }

    // Legacy — kept as-is pending Phase 2 email reminders.
    match /globalSubscribers/{document=**} {
      allow create: if request.resource.data.keys().hasAll(['email', 'subscribedAt', 'active']);
      allow read, update, delete: if false;
    }

    match /dateSubscribers/{document=**} {
      allow create: if request.resource.data.keys().hasAll(['email', 'date', 'subscribedAt', 'active']);
      allow read, update, delete: if false;
    }

    match /reminderLog/{document=**} {
      allow read, write: if false;
    }
  }
}
